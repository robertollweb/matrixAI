## Example env for MatrixAI LLM bridge
# Copy to .env or set the variables in your deployment environment.

# Leave MATRIXAI_LLM_API_KEY empty to run in deterministic mode.
MATRIXAI_LLM_API_KEY=
MATRIXAI_LLM_MODEL=gpt-4o-mini
MATRIXAI_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
MATRIXAI_LLM_PROVIDER_NAME=openai

# Optional tuning
MATRIXAI_LLM_TEMPERATURE=0.0
MATRIXAI_LLM_CANDIDATES=1
MATRIXAI_LLM_TIMEOUT=30
MATRIXAI_LLM_MAX_RETRIES=3
MATRIXAI_LLM_TOKEN_BUDGET=0
MATRIXAI_LLM_RETRY_DELAY=1.0
MATRIXAI_LLM_ENV_FILE=.env

# Supported providers (MATRIXAI_LLM_PROVIDER_NAME) and their default endpoints.
# Leave MATRIXAI_LLM_ENDPOINT empty to use the provider default below.
#
# openai     -> https://api.openai.com/v1/chat/completions          (e.g. gpt-4o-mini)
# deepseek   -> https://api.deepseek.com/chat/completions           (e.g. deepseek-chat)
# gemini     -> https://generativelanguage.googleapis.com/v1beta/openai/chat/completions  (e.g. gemini-2.0-flash)
# anthropic  -> https://api.anthropic.com/v1/messages               (e.g. claude-opus-4-8)
#
# For Anthropic (Claude) — Messages API, x-api-key auth, no temperature sent:
# MATRIXAI_LLM_PROVIDER_NAME=anthropic
# MATRIXAI_LLM_MODEL=claude-opus-4-8
# MATRIXAI_LLM_API_KEY=sk-ant-...
# MATRIXAI_LLM_MAX_TOKENS=4096          # required by the Messages API
#
# For Google Gemini (OpenAI-compatible endpoint):
# MATRIXAI_LLM_PROVIDER_NAME=gemini
# MATRIXAI_LLM_MODEL=gemini-2.0-flash
#
# For DeepSeek (OpenAI-compatible endpoint):
# MATRIXAI_LLM_PROVIDER_NAME=deepseek
# MATRIXAI_LLM_MODEL=deepseek-chat

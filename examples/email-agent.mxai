PROJECT EmailAgent

VECTOR Email[8]
  urgency
  sender_trust
  topic_support
  topic_sales
  sentiment
  has_attachment
  previous_interactions
  language_confidence
END

FUNCTION Classifier
  C = softmax(W1 * Email + b1)
END

FUNCTION ReplyActivation
  A = sigmoid(50 * (Confidence.max - 0.95))
END

DISTRIBUTION Confidence
  Confidence ~ Categorical(C)
END

GRAPH
  Email -> Classifier -> Confidence -> ReplyActivation -> DraftReply
END

ACTION DraftReply
  WHEN ReplyActivation > 0.90
  POLICY simulate_only
  CALL simulated.email.draft
END

AUDIT
  EXPLAIN Email -> Classifier -> Confidence -> ReplyActivation -> DraftReply
END
